{
  "name": "disaster-recovery-system",
  "version": "1.0.0",
  "description": "Complete Disaster Recovery System for MongoDB on AWS EC2",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "backup": "cd scripts && ./full-backup.sh",
    "restore": "cd scripts && ./restore-now.sh",
    "status": "cd scripts && ./check-status.sh",
    "setup": "chmod +x scripts/*.sh && ./scripts/setup.sh"
  },
  "keywords": [
    "disaster-recovery",
    "mongodb",
    "aws",
    "backup",
    "restore",
    "nodejs"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongodb": "^5.5.0",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
